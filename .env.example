# Firebase web app configuration.
# Copy this file to `.env` (which is gitignored) and fill in the values from:
# Firebase Console -> Project settings -> General -> Your apps -> Web app -> SDK setup and configuration.
#
# Before the app works end-to-end, in the Firebase Console enable:
#   - Authentication -> Sign-in method -> Google AND Email/Password
#   - Firestore Database -> Create database

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- Optional: AI features (OpenAI via a secure server-side proxy) ----
# The AI tutor, adaptive feedback, AI Lab, free-response graders, review/recap
# generators, etc. are OFF by default. They call a Netlify Edge Function proxy
# (netlify/edge-functions/ai.ts) that holds the OpenAI key server-side — the key
# is NEVER exposed to the browser. See netlify/README.md for proxy deploy + env.
#
# To turn them on:
#   1. Deploy the Netlify proxy and set OPENAI_API_KEY, FIREBASE_PROJECT_ID, and
#      ALLOWED_ORIGIN (your app's origin) in the Netlify dashboard.
#   2. Set the two vars below, then rebuild. VITE_AI_PROXY_URL is the absolute
#      proxy URL (your Netlify site + /api/ai).
VITE_AI_ENABLED=false
VITE_AI_PROXY_URL=https://YOUR-SITE.netlify.app/api/ai

# Optional: pin a specific OpenAI model. Leave unset to use the proxy default.
# VITE_OPENAI_MODEL=gpt-4o-mini
