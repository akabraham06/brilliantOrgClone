rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Light shape check for the account-level economy map (XP/coins/cosmetics)
    // stored on the user doc. Owner-only access is the real guard; this just keeps
    // the data well-formed and non-negative. Passes when no economy is written.
    function economyValid() {
      return !('economy' in request.resource.data)
        || (
          request.resource.data.economy.xp is number
          && request.resource.data.economy.xp >= 0
          && request.resource.data.economy.coins is number
          && request.resource.data.economy.coins >= 0
          && request.resource.data.economy.ownedCosmetics is list
        );
    }

    // Light shape check for the persistent learner-memory map (rolling AI summary,
    // misconception ledger, spaced-repetition cards) stored on the user doc.
    // Owner-only access is the real guard; this just keeps the data well-formed.
    // Passes when no learnerMemory is written (e.g. an economy-only merge write).
    function learnerMemoryValid() {
      return !('learnerMemory' in request.resource.data)
        || (
          request.resource.data.learnerMemory is map
          && (
            !('summary' in request.resource.data.learnerMemory)
            || (
              request.resource.data.learnerMemory.summary is string
              && request.resource.data.learnerMemory.summary.size() <= 2000
            )
          )
          && (
            !('misconceptions' in request.resource.data.learnerMemory)
            || request.resource.data.learnerMemory.misconceptions is map
          )
          && (
            !('srs' in request.resource.data.learnerMemory)
            || request.resource.data.learnerMemory.srs is map
          )
        );
    }

    // User profile (incl. the economy + learnerMemory maps): owner-only read/write.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && economyValid() && learnerMemoryValid();
    }

    // Course content is readable by any signed-in learner. Client writes are
    // disallowed; content is populated by the admin seed script (which bypasses
    // these rules via the Admin SDK).
    match /courses/{courseId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /lessons/{lessonId} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /slides/{slideId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Per-user progress: owner-only. Documents carry a `uid` field and the
    // owner must match the authenticated user on every operation.
    match /userCourseProgress/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }
    match /userLessonProgress/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }
    match /userSlideProgress/{docId} {
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
    }

    // Light shape check for a Heat Check leaderboard score doc: a non-negative
    // numeric bestXp and a sane-length displayName. Owner-only WRITE (your own
    // uid) is the real guard; reads are open to any signed-in learner so the
    // global ladder can be displayed.
    function heatScoreValid(uid) {
      return request.auth.uid == uid
        && request.resource.data.bestXp is number
        && request.resource.data.bestXp >= 0
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 80;
    }

    // All-time (Section B): one lifetime-best doc per player, keyed by uid.
    match /heatLeaderboard/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && heatScoreValid(uid);
    }

    // Weekly (Section A): each ISO week is its own `scores` subcollection so it
    // resets automatically. Same open-read / owner-only-write guard.
    match /heatWeekly/{weekKey}/scores/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && heatScoreValid(uid);
    }
  }
}
